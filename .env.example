# Copy to .env at repo root. Compose reads these for provider selection + keys.
# The infra/docker-compose.yml supplies DB/Redis/S3 wiring automatically;
# you only need to set the AI provider choices + keys here (optional).

# AI providers — leave as 'local' to run with no keys (stub embeddings/LLM),
# or switch to real providers and add keys for production-quality results.
# Gemini covers BOTH embeddings + LLM from one key (set both PROVIDERs=gemini).
# Free-tier note: gemini-2.5-flash allows only ~20 LLM requests/day — use
# gemini-2.5-flash-lite (LLM_MODEL below) for a far higher daily quota.
EMBED_PROVIDER=local           # local | openai | gemini
LLM_PROVIDER=local             # local | anthropic | gemini
LLM_MODEL=gemini-2.5-flash-lite
EMBED_DIM=3072

# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...
# GEMINI_API_KEY=...           # https://aistudio.google.com/apikey
# Multiple keys from DIFFERENT GCP projects multiply your daily quota — the
# client rotates to the next key on 429. (Keys in the SAME project share quota.)
# GEMINI_API_KEYS=key1,key2,key3

# Gemini throughput vs. free-tier rate limits. Requests are paced to these
# per-minute budgets and auto-retry on 429 (honoring the server's retryDelay),
# so big files slow down instead of failing. Raise if your key has higher quota.
# GEMINI_LLM_RPM=10            # generateContent requests/min (flash free tier)
# GEMINI_EMBED_RPM=100         # (batch)embedContent requests/min
# GEMINI_MAX_CONCURRENCY=4     # max simultaneous in-flight requests
# GEMINI_MAX_RETRIES=5         # retries on 429/503 before giving up
# INSIGHT_BATCH=8              # chunks per insight extraction request

# Media extraction (optional; unset providers make media sources 'partial')
# TRANSCRIBE_PROVIDER=deepgram
# DEEPGRAM_API_KEY=...
