# ── Database ──────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/research_repo?schema=public"

# ── Embeddings (optional at seed time) ────────────────────
# If set, the seed embeds each flow-stage description so classification works
# immediately. Leave unset to seed with NULL embeddings and backfill later.
EMBED_DIM=3072
EMBED_MODEL=text-embedding-3-large
# OPENAI_API_KEY=sk-...
# SEED_EMBEDDINGS=false   # force-skip embedding during seed

# ── Classifier ────────────────────────────────────────────
CLASSIFY_THRESHOLD=0.30
