{
  "compilerOptions": {
    "target": "ES2022", "module": "ESNext", "moduleResolution": "Bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"], "jsx": "preserve",
    "strict": true, "esModuleInterop": true, "skipLibCheck": true, "noEmit": true,
    "allowJs": true, "incremental": true, "resolveJsonModule": true, "isolatedModules": true,
    "baseUrl": "src", "paths": { "@/*": ["*"] },
    "plugins": [{ "name": "next" }]
  },
  "include": ["src", "next-env.d.ts", ".next/types/**/*.ts", "next.config.mjs"],
  "exclude": ["node_modules"]
}
