# ── App ───────────────────────────────────────────────────
APP_URL=http://localhost:3000
NODE_ENV=development

# ── Database (Prisma 7 reads this via prisma.config.ts) ────
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/research_repo?schema=public"

# ── Queue (omit to run pipeline inline, no Redis needed) ───
# REDIS_URL=redis://localhost:6379
PIPELINE_CONCURRENCY=4

# ── Object storage (S3 / R2 / MinIO) ──────────────────────
S3_ENDPOINT=http://localhost:9000      # MinIO; unset for real S3
S3_BUCKET=research-repo
S3_REGION=auto
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=minioadmin

# ── AI providers (omit keys to use the local stub) ────────
EMBED_PROVIDER=local                   # local | openai | gemini
EMBED_DIM=3072
EMBED_MODEL=text-embedding-3-large     # OpenAI only; Gemini uses GEMINI_EMBED_MODEL
# OPENAI_API_KEY=sk-...
# GEMINI_API_KEY=...                   # https://aistudio.google.com/apikey
GEMINI_EMBED_MODEL=gemini-embedding-001

# ── Pipeline tuning ───────────────────────────────────────
CHUNK_TOKENS=400
CHUNK_OVERLAP=60
CLASSIFY_THRESHOLD=0.30

# ── LLM (Pass B classify + insight extraction; omit to use stub) ──
LLM_PROVIDER=local                     # local | anthropic | gemini
# ANTHROPIC_API_KEY=sk-ant-...
LLM_MODEL=claude-sonnet-4-6            # gemini: use gemini-2.5-flash-lite (flash free tier is only ~20 req/day)

# ── Gemini rate limiting (paces requests to free-tier RPM; 429 auto-retry) ──
GEMINI_LLM_RPM=10                      # generateContent requests/min
GEMINI_EMBED_RPM=100                   # (batch)embedContent requests/min
GEMINI_MAX_CONCURRENCY=4               # max simultaneous in-flight requests
GEMINI_MAX_RETRIES=5                   # retries on 429/503 before giving up
INSIGHT_BATCH=8                        # chunks per insight extraction request

# ── Media extraction (omit to skip; source becomes 'partial') ─────
TRANSCRIBE_PROVIDER=noop               # noop | deepgram
# DEEPGRAM_API_KEY=...
OCR_PROVIDER=tesseract                 # tesseract | noop
DOC_PROVIDER=local                     # local | noop

# ── Insight dedupe ────────────────────────────────────────
INSIGHT_DEDUPE_SCORE=0.90
